# Electroneum Network RPC URLs
# Mainnet: https://forno.electroneum.org
# Testnet Testnet: https://testnet-forno.electroneum-testnet.org
ELECTRONEUM_RPC_URL=https://forno.electroneum.org
ELECTRONEUM_ALFAJORES_RPC_URL=https://testnet-forno.electroneum-testnet.org

# Electroneum Explorer API Key (optional, for contract verification)
# Get one at: https://electroneumscan.io
ELECTRONEUMSCAN_API_KEY=your_api_key_here
